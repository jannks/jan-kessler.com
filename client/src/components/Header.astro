---
import LucideIcon from './LucideIcon.astro';
import ThemeIcon from './ThemeIcon.astro';
---

<header>
    <nav class="container">
        <div class="pill">
            <a href="/" class="logo" aria-label="Jan Kessler">
                JK<span class="logo-dot">.</span>
            </a>
            <div class="actions">
                <a
                    href="https://github.com/jannks"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="icon-button"
                    aria-label="GitHub"
                >
                    <LucideIcon name="github" size={22} />
                </a>
                <ThemeIcon />
            </div>
        </div>
    </nav>
</header>

<style>
    header {
        position: fixed;
        top: 1.5rem;
        left: 0;
        right: 0;
        z-index: 50;
    }

    .pill {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--surface);
        border: 4px solid var(--border);
        border-radius: 9999px;
        padding: 0.625rem 1.25rem;
        box-shadow: 8px 8px 0 0 var(--shadow);
    }

    .logo {
        font-weight: 900;
        font-size: 1.5rem;
        letter-spacing: -0.04em;
        color: var(--ink);
    }

    .logo-dot {
        color: var(--accent);
        font-size: 1.875rem;
        line-height: 1;
    }

    .actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .icon-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        background: var(--ink);
        color: var(--ink-inverse);
        border: 2px solid var(--border);
        border-radius: 9999px;
        transition: background 0.2s ease;
    }

    .icon-button:hover {
        background: var(--accent);
        color: var(--ink);
    }
</style>
