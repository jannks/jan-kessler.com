---
import LucideIcon from './LucideIcon.astro';
import ThemeIcon from './ThemeIcon.astro';
---

<header>
    <nav class="container">
        <div class="bar">
            <a href="/" class="logo" aria-label="Jan Kessler">
                <span class="logo-mark">JK</span>
                <svg
                    class="logo-spark"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <path
                        d="M12 2 L13.5 9.5 L21 11 L13.5 12.5 L12 20 L10.5 12.5 L3 11 L10.5 9.5 Z"
                        fill="currentColor"
                    ></path>
                </svg>
            </a>
            <div class="actions">
                <a href="/freelance" class="nav-link">Freelance</a>
                <a
                    href="https://github.com/jannks"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="icon-button"
                    aria-label="GitHub"
                >
                    <LucideIcon name="github" size={20} />
                </a>
                <ThemeIcon />
            </div>
        </div>
    </nav>
</header>

<style>
    header {
        position: fixed;
        top: 1.25rem;
        left: 0;
        right: 0;
        z-index: 50;
    }

    .bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 0.75rem;
        padding: 0.5rem 0.75rem 0.5rem 1rem;
        box-shadow: 4px 4px 0 0 var(--shadow);
    }

    .logo {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-display);
        font-size: 1.25rem;
        letter-spacing: 0.02em;
        color: var(--ink);
        padding-right: 1.1rem;
    }

    .logo-mark {
        line-height: 1;
    }

    .logo-spark {
        position: absolute;
        right: 0;
        top: -0.35rem;
        width: 0.95rem;
        height: 0.95rem;
        color: var(--accent);
        transform: rotate(15deg);
        animation: twinkle 2.4s ease-in-out infinite;
    }

    @keyframes twinkle {
        0%, 100% { transform: rotate(15deg) scale(1); opacity: 1; }
        50% { transform: rotate(15deg) scale(0.7); opacity: 0.6; }
    }

    .actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .nav-link {
        font-family: var(--font-mono);
        font-weight: 500;
        font-size: 0.8125rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        color: var(--ink);
        transition:
            background 0.15s ease,
            color 0.15s ease,
            transform 0.15s ease;
    }

    .nav-link:hover {
        background: var(--accent);
        color: #ffffff;
        transform: rotate(-2deg);
    }

    @media (max-width: 480px) {
        .nav-link {
            display: none;
        }
    }

    .icon-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        background: var(--surface);
        color: var(--ink);
        border: 2px solid var(--border);
        border-radius: 0.5rem;
        transition:
            background 0.15s ease,
            color 0.15s ease,
            transform 0.15s ease;
    }

    .icon-button:hover {
        background: var(--accent);
        color: #ffffff;
        transform: translate(-1px, -1px) rotate(-4deg);
    }
</style>
