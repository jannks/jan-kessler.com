---
import LucideIcon from './LucideIcon.astro';
import ThemeIcon from './ThemeIcon.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getLocale } from '../i18n/utils';
import { getDictionary } from '../i18n/ui';
import { localizeHref } from '../i18n/utils';

const locale = getLocale(Astro);
const dict = await getDictionary(locale);
const links = dict.nav.links ?? [];
const socials = dict.nav.socials ?? [];
const isExternal = (href: string): boolean => /^https?:\/\//.test(href);
const resolveHref = (href: string): string =>
    isExternal(href) ? href : localizeHref(href, locale);

const SOCIAL_LABELS: Record<string, string> = {
    github: 'GitHub',
    linkedin: 'LinkedIn',
};
---

<header>
    <nav class="container">
        <div class="bar">
            <a href={localizeHref('/', locale)} class="logo" aria-label="Jan Kessler">
                <span class="logo-mark">JK</span>
                <svg
                    class="logo-spark"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                >
                    <path
                        d="M12 2 L13.5 9.5 L21 11 L13.5 12.5 L12 20 L10.5 12.5 L3 11 L10.5 9.5 Z"
                        fill="currentColor"
                    ></path>
                </svg>
            </a>
            <div class="actions">
                <div class="desktop-nav">
                    {
                        links.map((link) => {
                            const href = resolveHref(link.href);
                            const external = isExternal(link.href);
                            return (
                                <a
                                    href={href}
                                    target={external ? '_blank' : undefined}
                                    rel={external ? 'noopener noreferrer' : undefined}
                                    class="nav-link"
                                >
                                    {link.label}
                                </a>
                            );
                        })
                    }
                    {
                        socials.map((social) => {
                            const label = SOCIAL_LABELS[social.platform];
                            return (
                                <a
                                    href={social.href}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="icon-button"
                                    aria-label={label}
                                >
                                    <LucideIcon name={social.platform} size={20} />
                                </a>
                            );
                        })
                    }
                </div>
                <LanguageSwitcher />
                <ThemeIcon />
                <button
                    type="button"
                    class="burger"
                    aria-label={dict.nav.menuOpenAria}
                    aria-expanded="false"
                    aria-controls="mobile-menu"
                    data-menu-toggle
                >
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                </button>
            </div>
        </div>
    </nav>

    <div
        id="mobile-menu"
        class="mobile-menu"
        role="dialog"
        aria-modal="true"
        aria-label={dict.nav.menuOpenAria}
        hidden
        data-menu
    >
        <ul class="mobile-menu-list">
            {
                links.map((link) => {
                    const href = resolveHref(link.href);
                    const external = isExternal(link.href);
                    return (
                        <li>
                            <a
                                href={href}
                                target={external ? '_blank' : undefined}
                                rel={external ? 'noopener noreferrer' : undefined}
                                class="mobile-link"
                            >
                                {link.label}
                            </a>
                        </li>
                    );
                })
            }
        </ul>
        {
            socials.length > 0 && (
                <div class="mobile-socials">
                    {socials.map((social) => {
                        const label = SOCIAL_LABELS[social.platform];
                        return (
                            <a
                                href={social.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="icon-button"
                                aria-label={label}
                            >
                                <LucideIcon name={social.platform} size={20} />
                            </a>
                        );
                    })}
                </div>
            )
        }
    </div>
</header>

<script
    is:inline
    define:vars={{
        openLabel: dict.nav.menuOpenAria,
        closeLabel: dict.nav.menuCloseAria,
    }}
>
    (() => {
        const toggle = document.querySelector('[data-menu-toggle]');
        const menu = document.querySelector('[data-menu]');
        if (!toggle || !menu) return;

        const setOpen = (open) => {
            toggle.setAttribute('aria-expanded', String(open));
            toggle.setAttribute('aria-label', open ? closeLabel : openLabel);
            toggle.classList.toggle('is-open', open);
            menu.toggleAttribute('hidden', !open);
            document.body.classList.toggle('menu-open', open);
        };

        toggle.addEventListener('click', () => {
            setOpen(toggle.getAttribute('aria-expanded') !== 'true');
        });

        menu.addEventListener('click', (event) => {
            if (event.target instanceof HTMLAnchorElement) {
                setOpen(false);
            }
        });

        document.addEventListener('keydown', (event) => {
            if (
                event.key === 'Escape' &&
                toggle.getAttribute('aria-expanded') === 'true'
            ) {
                setOpen(false);
                toggle.focus();
            }
        });
    })();
</script>

<style>
    header {
        position: fixed;
        top: 1.25rem;
        left: 0;
        right: 0;
        z-index: 50;
    }

    .bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 0.75rem;
        padding: 0.5rem 0.75rem 0.5rem 1rem;
        box-shadow: 4px 4px 0 0 var(--shadow);
    }

    .logo {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        font-family: var(--font-display);
        font-size: 1.25rem;
        letter-spacing: 0.02em;
        color: var(--ink);
        padding-right: 1.1rem;
    }

    .logo-mark {
        line-height: 1;
    }

    .logo-spark {
        position: absolute;
        right: 0;
        top: -0.35rem;
        width: 0.95rem;
        height: 0.95rem;
        color: var(--accent);
        transform: rotate(15deg);
        animation: twinkle 2.4s ease-in-out infinite;
    }

    @keyframes twinkle {
        0%, 100% { transform: rotate(15deg) scale(1); opacity: 1; }
        50% { transform: rotate(15deg) scale(0.7); opacity: 0.6; }
    }

    .actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .desktop-nav {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .nav-link {
        font-family: var(--font-mono);
        font-weight: 500;
        font-size: 0.8125rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        padding: 0.5rem 0.75rem;
        border-radius: 0.5rem;
        color: var(--ink);
        transition:
            background 0.15s ease,
            color 0.15s ease,
            transform 0.15s ease;
    }

    .nav-link:hover {
        background: var(--accent);
        color: #ffffff;
        transform: rotate(-2deg);
    }

    .icon-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.25rem;
        height: 2.25rem;
        background: var(--surface);
        color: var(--ink);
        border: 2px solid var(--border);
        border-radius: 0.5rem;
        transition:
            background 0.15s ease,
            color 0.15s ease,
            transform 0.15s ease;
    }

    .icon-button:hover {
        background: var(--accent);
        color: #ffffff;
        transform: translate(-1px, -1px) rotate(-4deg);
    }

    .burger {
        display: none;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 0.25rem;
        width: 2.25rem;
        height: 2.25rem;
        padding: 0;
        background: var(--surface);
        color: var(--ink);
        border: 2px solid var(--border);
        border-radius: 0.5rem;
        cursor: pointer;
        transition:
            background 0.15s ease,
            color 0.15s ease,
            transform 0.15s ease;
    }

    .burger:hover {
        background: var(--accent);
        color: #ffffff;
        transform: translate(-1px, -1px) rotate(-4deg);
    }

    .burger span {
        display: block;
        width: 1.1rem;
        height: 2px;
        background: currentColor;
        border-radius: 2px;
        transition: transform 0.2s ease, opacity 0.2s ease;
    }

    .burger.is-open span:nth-child(1) {
        transform: translateY(6px) rotate(45deg);
    }

    .burger.is-open span:nth-child(2) {
        opacity: 0;
    }

    .burger.is-open span:nth-child(3) {
        transform: translateY(-6px) rotate(-45deg);
    }

    .mobile-menu {
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 1rem;
        right: 1rem;
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 0.75rem;
        box-shadow: 4px 4px 0 0 var(--shadow);
        padding: 0.75rem;
        z-index: 49;
    }

    .mobile-menu[hidden] {
        display: none;
    }

    .mobile-menu-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .mobile-link {
        display: block;
        padding: 0.75rem 0.875rem;
        font-family: var(--font-mono);
        font-weight: 500;
        font-size: 0.875rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--ink);
        border-radius: 0.5rem;
        transition: background 0.15s ease, color 0.15s ease;
    }

    .mobile-link:hover {
        background: var(--accent);
        color: #ffffff;
    }

    .mobile-socials {
        display: flex;
        gap: 0.5rem;
        padding: 0.75rem 0.875rem 0.25rem;
        margin-top: 0.5rem;
        border-top: 1px solid var(--border);
    }

    @media (max-width: 640px) {
        .desktop-nav {
            display: none;
        }

        .burger {
            display: inline-flex;
        }
    }
</style>
