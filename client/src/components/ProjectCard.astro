---
import type { Project } from '../types/payload-types';
import { serialize } from '../utils/slate-text.converter';
import Chip from './Chip.astro';
import LucideIcon from './LucideIcon.astro';

interface Props {
    project: Project;
    index: number;
}

const { project, index } = Astro.props;

const palette = [
    'var(--card-1)',
    'var(--card-2)',
    'var(--card-3)',
    'var(--card-4)',
];
const tapeColors = [
    'var(--card-3)',
    'var(--card-4)',
    'var(--card-1)',
    'var(--card-2)',
];
const stampLabels = ['shipped', 'live', 'in prod', 'still up'];
const cardBg = palette[index % palette.length];
const tapeBg = tapeColors[index % tapeColors.length];
const stampLabel = stampLabels[index % stampLabels.length];
const tilt = index % 2 === 0 ? -1.2 : 1.2;
const tapeTilt = index % 2 === 0 ? -8 : 6;
const cardNumber = String(index + 1).padStart(2, '0');
---

<article
    class="card"
    style={`--card-bg: ${cardBg}; --card-tape: ${tapeBg}; --card-tilt: ${tilt}deg; --tape-tilt: ${tapeTilt}deg;`}
>
    <span class="tape" aria-hidden="true"></span>
    <span class="card-number mono">№ {cardNumber}</span>

    <div class="card-content">
        <header class="card-head">
            <div class="card-titles">
                <h3 class="card-title">{project.title}</h3>
                {
                    project.copmanyName && (
                        <a
                            href={project.copmanyUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="company-pill mono"
                        >
                            {project.copmanyName}
                        </a>
                    )
                }
            </div>
            {
                project.projectUrl && (
                    <a
                        href={project.projectUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="external-link"
                        aria-label={`Open ${project.title}`}
                    >
                        <LucideIcon name="external-link" size={20} />
                    </a>
                )
            }
        </header>

        <div class="card-description" set:html={serialize(project.description)}>
        </div>

        <div class="card-footer">
            <div class="card-tags">
                {project.technologies.map((tag) => <Chip label={tag} />)}
            </div>
            <span class="stamp">{stampLabel}</span>
        </div>
    </div>
</article>

<style>
    .card {
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        height: 100%;
        background: var(--card-bg);
        color: var(--card-ink);
        border: 2px solid var(--border);
        border-radius: 0.75rem;
        overflow: visible;
        box-shadow: 6px 6px 0 0 var(--shadow);
        transform: rotate(var(--card-tilt, 0deg));
        transition:
            transform 0.25s ease,
            box-shadow 0.25s ease;
    }

    .card:hover {
        transform: rotate(0deg) translate(-3px, -3px);
        box-shadow: 10px 10px 0 0 var(--shadow);
    }

    /* washi tape on top */
    .tape {
        position: absolute;
        top: -0.7rem;
        left: 50%;
        width: 5.5rem;
        height: 1.3rem;
        background: var(--card-tape);
        border: 2px solid var(--border);
        transform: translateX(-50%) rotate(var(--tape-tilt, -6deg));
        z-index: 3;
        pointer-events: none;
        opacity: 0.95;
    }

    .card-number {
        position: absolute;
        top: 0.625rem;
        right: 0.875rem;
        font-size: 0.6875rem;
        font-weight: 700;
        color: var(--card-ink);
        opacity: 0.6;
        z-index: 2;
        pointer-events: none;
    }

    .card-content {
        position: relative;
        display: flex;
        flex-direction: column;
        flex: 1;
        padding: 1.75rem 1.5rem 1.5rem;
        gap: 1.25rem;
    }

    @media (min-width: 768px) {
        .card-content {
            padding: 2rem 1.875rem 1.75rem;
        }
    }

    .card-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
    }

    .card-titles {
        display: flex;
        flex-direction: column;
        gap: 0.625rem;
        min-width: 0;
    }

    .card-title {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3.5vw, 2.125rem);
        line-height: 1;
        letter-spacing: -0.02em;
        margin: 0;
        text-transform: uppercase;
        overflow-wrap: anywhere;
        color: var(--card-ink);
    }

    .company-pill {
        display: inline-block;
        align-self: flex-start;
        padding: 0.25rem 0.625rem;
        background: var(--card-ink);
        color: var(--card-bg);
        font-size: 0.6875rem;
        font-weight: 500;
        text-transform: uppercase;
        border: 2px solid var(--border);
        border-radius: 0.375rem;
        transform: rotate(-1deg);
        transition:
            background 0.15s ease,
            color 0.15s ease,
            transform 0.15s ease;
    }

    .company-pill:hover {
        background: var(--accent);
        color: #ffffff;
        transform: rotate(0deg);
    }

    .external-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        width: 2.5rem;
        height: 2.5rem;
        background: var(--card-ink);
        color: var(--card-bg);
        border: 2px solid var(--border);
        border-radius: 0.5rem;
        box-shadow: 3px 3px 0 0 var(--shadow);
        transition:
            background 0.15s ease,
            color 0.15s ease,
            transform 0.15s ease,
            box-shadow 0.15s ease;
    }

    .external-link:hover {
        background: var(--accent);
        color: #ffffff;
        transform: translate(-2px, -2px) rotate(-4deg);
        box-shadow: 5px 5px 0 0 var(--shadow);
    }

    .card-description {
        font-size: 0.9375rem;
        font-weight: 500;
        line-height: 1.55;
        color: var(--card-ink);
        flex: 1;
    }

    .card-description :global(p) {
        margin: 0 0 0.5rem;
    }

    .card-description :global(p:last-child) {
        margin-bottom: 0;
    }

    .card-footer {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 0.75rem;
        margin-top: auto;
    }

    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        flex: 1;
    }

    .stamp {
        flex-shrink: 0;
        align-self: flex-end;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.25rem 0.5rem;
        border: 2px solid currentColor;
        border-radius: 0.25rem;
        color: var(--accent);
        transform: rotate(-6deg);
        background: transparent;
    }
</style>
