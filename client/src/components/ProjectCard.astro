---
import type { Project } from '../types/payload-types';
import { serialize } from '../utils/slate-text.converter';
import Chip from './Chip.astro';
import LucideIcon from './LucideIcon.astro';

interface Props {
    project: Project;
    index: number;
}

const { project, index } = Astro.props;
const isEven = index % 2 === 0;
---

<article class:list={['card', { 'card--alt': !isEven }]}>
    <div
        class:list={['card-deco', { 'card-deco--alt': !isEven }]}
        aria-hidden="true"
    >
    </div>

    <div class="card-content">
        <div class="card-head">
            <div class="card-titles">
                <h3 class="card-title">{project.title}</h3>
                {
                    project.copmanyName && (
                        <a
                            href={project.copmanyUrl}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="company-pill"
                        >
                            {project.copmanyName}
                        </a>
                    )
                }
            </div>
            {
                project.projectUrl && (
                    <a
                        href={project.projectUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="external-link"
                        aria-label={`Open ${project.title}`}
                    >
                        <LucideIcon name="external-link" size={22} />
                    </a>
                )
            }
        </div>

        <div class="card-description" set:html={serialize(project.description)}>
        </div>

        <div class="card-tags">
            {project.technologies.map((tag) => <Chip label={tag} />)}
        </div>
    </div>
</article>

<style>
    .card {
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        background: var(--surface);
        color: var(--ink);
        border: 4px solid var(--border);
        border-radius: 3rem;
        padding: 2rem;
        box-shadow: 16px 16px 0 0 var(--shadow);
        transform: rotate(1deg);
        overflow: hidden;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    .card--alt {
        transform: rotate(-1deg);
    }

    .card:hover {
        transform: rotate(0deg) translateY(-0.5rem);
        box-shadow: 24px 24px 0 0 var(--shadow);
    }

    @media (min-width: 768px) {
        .card {
            padding: 2.5rem;
        }
    }

    .card-deco {
        position: absolute;
        right: -3rem;
        bottom: -3rem;
        width: 10rem;
        height: 10rem;
        border: 4px solid var(--border);
        border-radius: 9999px;
        background: var(--accent);
        opacity: 0.2;
        transition: transform 0.7s ease;
        pointer-events: none;
    }

    .card-deco--alt {
        background: var(--accent-soft);
    }

    .card:hover .card-deco {
        transform: scale(1.5);
    }

    .card-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        flex: 1;
    }

    .card-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }

    .card-titles {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        min-width: 0;
    }

    .card-title {
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.04em;
        margin: 0;
        overflow-wrap: anywhere;
    }

    .company-pill {
        display: inline-block;
        align-self: flex-start;
        padding: 0.375rem 1rem;
        background: var(--ink);
        color: var(--ink-inverse);
        font-size: 0.8125rem;
        font-weight: 700;
        border: 2px solid var(--border);
        border-radius: 9999px;
        transform: rotate(-1deg);
    }

    .external-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        width: 3rem;
        height: 3rem;
        background: var(--accent-soft);
        color: #000;
        border: 4px solid var(--border);
        border-radius: 9999px;
        box-shadow: 4px 4px 0 0 var(--shadow);
        transition:
            background 0.2s ease,
            color 0.2s ease,
            transform 0.2s ease;
    }

    .external-link:hover {
        background: var(--accent);
        color: #ffffff;
        transform: translate(0.25rem, -0.25rem);
    }

    .card-description {
        font-size: 1.125rem;
        font-weight: 700;
        line-height: 1.6;
        flex: 1;
        margin-bottom: 2rem;
    }

    .card-description :global(p) {
        margin: 0 0 0.75rem;
    }

    .card-description :global(p:last-child) {
        margin-bottom: 0;
    }

    .card-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.625rem;
        margin-top: auto;
    }
</style>
