---
import { Image } from 'astro:assets';
import LucideIcon from './LucideIcon.astro';
import { getLocale, localizeHref } from '../i18n/utils';
import { getDictionary } from '../i18n/ui';
import portraitImage from '../assets/portrait.webp';

const locale = getLocale(Astro);
const dict = await getDictionary(locale);
const t = dict.intro;
---

<section class="intro">
    <div class="container intro-grid">
        <div class="status-row">
            <span class="status fade-in">
                <span class="status-dot" aria-hidden="true"></span>
                <span class="mono">{t.status}</span>
            </span>
        </div>

        <div class="name fade-in">
            <div class="name-row">
                <span class="initial">J</span><span class="rest slide-in">an</span>
            </div>

            <svg
                class="squiggle"
                viewBox="0 0 200 18"
                preserveAspectRatio="none"
                aria-hidden="true"
            >
                <path
                    d="M 2 9 Q 14 1 28 9 T 56 9 T 84 9 T 112 9 T 140 9 T 168 9 T 196 9"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3.5"
                    stroke-linecap="round"
                ></path>
            </svg>

            <div class="name-row">
                <span class="initial">K</span><span class="rest slide-in">essler</span>
            </div>
        </div>

        <div class="middle">
            <div class="polaroid fade-in" aria-hidden="false">
                <span class="tape tape-tl" aria-hidden="true"></span>
                <span class="tape tape-br" aria-hidden="true"></span>
                <Image
                    src={portraitImage}
                    alt={t.polaroidAlt}
                    widths={[176, 352, 528]}
                    sizes="(min-width: 768px) 11rem, 9rem"
                    quality={90}
                    loading="eager"
                    fetchpriority="high"
                />
                <span class="polaroid-caption mono">{t.polaroidCaption}</span>
            </div>

            <div class="meta fade-in">
                <p class="meta-line">
                    <span class="mono meta-kicker">{t.currentlyKicker}</span>
                    <span class="meta-text">
                        <span class="marker">{t.currentlyRole}</span> {t.currentlySuffix}
                        <span class="at">{t.currentlyAt}</span>
                        <a
                            href="https://ah-oh.de"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="employer-link"
                        >
                            Ah&amp;Oh
                        </a>
                    </span>
                </p>

                <p class="meta-line meta-line--secondary">
                    <span class="mono meta-kicker">{t.asideKicker}</span>
                    <span class="meta-text">{t.asideText}</span>
                </p>

                <a href={localizeHref('/freelance', locale)} class="freelance-sticker">
                    <span class="freelance-sticker-burst" aria-hidden="true"></span>
                    <span class="freelance-sticker-inner">
                        <LucideIcon name="sparkles" size={16} />
                        <span class="mono">{t.freelanceCta}</span>
                        <LucideIcon name="arrow-up-right" size={16} />
                    </span>
                </a>
            </div>
        </div>

        <a href="#projects" class="scroll-hint fade-in" aria-label={t.scrollAria}>
            <span class="scroll-handwritten">{t.scrollHint}</span>
            <svg
                class="scroll-arrow"
                viewBox="0 0 60 40"
                aria-hidden="true"
            >
                <path
                    d="M 4 6 Q 18 2 30 14 T 50 22"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                ></path>
                <path
                    d="M 50 22 L 44 16 M 50 22 L 44 28"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                ></path>
            </svg>
        </a>
    </div>
</section>

<style>
    .intro {
        min-height: 100vh;
        padding-top: 6.5rem;
        padding-bottom: 3rem;
        display: flex;
        align-items: center;
    }

    @media (min-width: 768px) {
        .intro {
            padding-top: 8.5rem;
            padding-bottom: 5rem;
        }
    }

    .intro-grid {
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: 2rem;
        position: relative;
    }

    /* status badge — slightly tilted */
    .status-row {
        display: flex;
    }

    .status {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.875rem;
        background: var(--surface);
        color: var(--ink);
        border: 2px solid var(--border);
        border-radius: 0.5rem;
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 500;
        box-shadow: 3px 3px 0 0 var(--shadow);
        transform: rotate(-1.5deg);
    }

    .status-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background: var(--accent);
        animation: pulse 1.6s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.85); }
    }

    /* name with squiggle */
    .name {
        font-family: var(--font-display);
        font-size: var(--display);
        line-height: 0.85;
        letter-spacing: -0.04em;
        text-transform: uppercase;
        color: var(--ink);
    }

    .name-row {
        display: flex;
        align-items: baseline;
        gap: 0.05em;
    }

    .name-row:nth-child(3) {
        margin-left: 0.6em;
        transform: rotate(-1deg);
        transform-origin: left top;
    }

    .squiggle {
        display: block;
        width: 8rem;
        height: 0.9rem;
        margin: 0.35em 0 0.35em 1.5em;
        color: var(--accent);
    }

    @media (min-width: 768px) {
        .squiggle {
            width: 14rem;
            height: 1.2rem;
        }
    }

    /* middle: polaroid + meta */
    .middle {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        align-items: flex-start;
    }

    @media (min-width: 768px) {
        .middle {
            flex-direction: row;
            align-items: center;
            gap: 2.5rem;
        }
    }

    .polaroid {
        position: relative;
        background: #ffffff;
        border: 2px solid var(--border);
        padding: 0.625rem 0.625rem 2rem;
        box-shadow: 5px 5px 0 0 var(--shadow);
        transform: rotate(-3deg);
        flex-shrink: 0;
        align-self: flex-start;
    }

    @media (min-width: 768px) {
        .polaroid {
            transform: rotate(-3.5deg);
        }
    }

    .polaroid img {
        display: block;
        width: 9rem;
        height: 9rem;
        object-fit: cover;
        object-position: center 25%;
        background: var(--card-2);
    }

    @media (min-width: 768px) {
        .polaroid img {
            width: 11rem;
            height: 11rem;
        }
    }

    .polaroid-caption {
        position: absolute;
        left: 0.625rem;
        right: 0.625rem;
        bottom: 0.5rem;
        text-align: center;
        font-size: 0.6875rem;
        text-transform: lowercase;
        color: #1a1612;
        letter-spacing: 0;
    }

    .tape {
        position: absolute;
        width: 4rem;
        height: 1.1rem;
        background: var(--card-1);
        border: 2px solid var(--border);
        opacity: 0.94;
    }

    .tape-tl {
        top: -0.6rem;
        left: -0.9rem;
        transform: rotate(-22deg);
    }

    .tape-br {
        bottom: -0.6rem;
        right: -0.9rem;
        transform: rotate(-18deg);
        background: var(--card-3);
    }

    /* meta */
    .meta {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        max-width: 32rem;
    }

    .meta-line {
        margin: 0;
        font-size: 1rem;
        line-height: 1.5;
        color: var(--ink);
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .meta-line--secondary .meta-text {
        color: var(--ink-muted);
        font-weight: 500;
    }

    .meta-kicker {
        font-size: 0.6875rem;
        color: var(--ink-muted);
        text-transform: uppercase;
    }

    .meta-text {
        font-weight: 600;
    }

    .at {
        color: var(--ink-muted);
        font-weight: 500;
    }

    .employer-link {
        position: relative;
        color: var(--ink);
        font-weight: 700;
    }

    .employer-link::after {
        content: '';
        position: absolute;
        left: -0.05em;
        right: -0.05em;
        bottom: -0.15em;
        height: 0.5em;
        background: var(--accent);
        z-index: -1;
        transform: skew(-8deg);
        transition: transform 0.2s ease;
    }

    .employer-link:hover::after {
        transform: skew(-8deg) scaleY(1.6);
    }

    /* freelance sticker */
    .freelance-sticker {
        position: relative;
        align-self: flex-start;
        margin-top: 0.25rem;
        padding: 0;
        border: none;
        background: transparent;
        transform: rotate(2deg);
        transition: transform 0.2s ease;
    }

    .freelance-sticker:hover {
        transform: rotate(0deg) scale(1.04);
    }

    .freelance-sticker-burst {
        position: absolute;
        inset: -0.4rem;
        background: var(--accent);
        border: 2px solid var(--border);
        clip-path: polygon(
            0% 35%, 8% 25%, 12% 38%, 22% 22%, 30% 38%, 40% 18%,
            48% 36%, 58% 20%, 66% 38%, 76% 22%, 86% 36%, 100% 28%,
            96% 50%, 100% 70%, 88% 64%, 80% 80%, 70% 64%, 60% 82%,
            50% 64%, 40% 82%, 30% 64%, 20% 80%, 10% 64%, 0% 72%,
            4% 50%
        );
    }

    .freelance-sticker-inner {
        position: relative;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        background: var(--card-1);
        color: var(--card-ink);
        border: 2px solid var(--border);
        border-radius: 0.4rem;
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 500;
        box-shadow: 3px 3px 0 0 var(--shadow);
    }

    /* scroll hint — handwritten + curved arrow */
    .scroll-hint {
        align-self: flex-end;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
        color: var(--ink);
        cursor: pointer;
        transition: transform 0.2s ease;
    }

    .scroll-hint:hover {
        transform: translateY(2px);
    }

    .scroll-handwritten {
        font-family: var(--font-display);
        font-size: 1rem;
        text-transform: lowercase;
        letter-spacing: 0;
        font-weight: 400;
        transform: rotate(-2deg);
    }

    .scroll-arrow {
        width: 3rem;
        height: 2rem;
        color: var(--accent);
        transform: rotate(8deg);
        transition: transform 0.2s ease;
    }

    .scroll-hint:hover .scroll-arrow {
        transform: rotate(8deg) translate(2px, 2px);
    }
</style>

<script>
    const scrollToProjects = (event: Event) => {
        event.preventDefault();
        document
            .getElementById('projects')
            ?.scrollIntoView({ behavior: 'smooth' });
    };

    document
        .querySelector('a[href="#projects"]')
        ?.addEventListener('click', scrollToProjects);
</script>
