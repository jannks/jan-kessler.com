---
import {
    getLocale,
    getLocalizedPath,
} from '../i18n/utils';
import { getDictionary, languageLabels, locales } from '../i18n/ui';

const currentLocale = getLocale(Astro);
const dict = await getDictionary(currentLocale);
---

<div class="language-switch" role="group" aria-label={dict.nav.languageAria}>
    {
        locales.map((locale) =>
            locale === currentLocale ? (
                <span class="lang-current mono" aria-current="true">
                    {languageLabels[locale]}
                </span>
            ) : (
                <a
                    href={getLocalizedPath(
                        Astro.url.pathname,
                        locale,
                        currentLocale,
                    )}
                    class="lang-link mono"
                    hreflang={locale}
                    aria-label={`${dict.nav.languageAria}: ${languageLabels[locale]}`}
                >
                    {languageLabels[locale]}
                </a>
            ),
        )
    }
</div>

<style>
    .language-switch {
        display: inline-flex;
        align-items: stretch;
        height: 2.25rem;
        background: var(--surface);
        border: 2px solid var(--border);
        border-radius: 0.5rem;
        overflow: hidden;
        box-shadow: 2px 2px 0 0 var(--shadow);
        transform: rotate(-1deg);
    }

    .lang-current,
    .lang-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0 0.5rem;
        font-size: 0.6875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        line-height: 1;
        min-width: 1.85rem;
    }

    .lang-current {
        background: var(--ink);
        color: var(--ink-inverse);
    }

    .lang-link {
        color: var(--ink);
        background: var(--surface);
        transition:
            background 0.15s ease,
            color 0.15s ease,
            transform 0.15s ease;
    }

    .lang-link:hover {
        background: var(--accent);
        color: #ffffff;
        transform: scale(1.05);
    }
</style>
