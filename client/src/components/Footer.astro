---
import { getLocale } from '../i18n/utils';
import { getDictionary } from '../i18n/ui';

const year = new Date().getFullYear();
const locale = getLocale(Astro);
const dict = await getDictionary(locale);
const text = dict.footer.text.replace('{year}', String(year));
---

<footer>
    <div class="container">
        <div class="badge mono">
            <span class="dot" aria-hidden="true"></span>
            <span>{text}</span>
            <svg
                class="heart"
                viewBox="0 0 24 24"
                aria-hidden="true"
            >
                <path
                    d="M12 21s-7-4.5-9.5-9.5C1 8 3.5 4 7 4c2 0 3.8 1 5 2.5C13.2 5 15 4 17 4c3.5 0 6 4 4.5 7.5C19 16.5 12 21 12 21z"
                    fill="currentColor"
                />
            </svg>
        </div>
    </div>
</footer>

<style>
    footer {
        padding-top: 4rem;
        padding-bottom: 2.5rem;
        text-align: center;
    }

    .container {
        display: flex;
        justify-content: center;
    }

    .badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--surface);
        color: var(--ink);
        padding: 0.5rem 0.875rem;
        border: 2px solid var(--border);
        border-radius: 0.5rem;
        box-shadow: 3px 3px 0 0 var(--shadow);
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 500;
        transform: rotate(-1deg);
    }

    .dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 9999px;
        background: var(--accent);
    }

    .heart {
        width: 0.85rem;
        height: 0.85rem;
        color: var(--accent);
    }
</style>
