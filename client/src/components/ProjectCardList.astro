---
import type { Project } from '@payload-types';
import LucideIcon from './LucideIcon.astro';
import ProjectCard from './ProjectCard.astro';
import { getLocale } from '../i18n/utils';
import { getDictionary } from '../i18n/ui';

const locale = getLocale(Astro);
const dict = await getDictionary(locale);
const t = dict.projects;

const apiUrl = import.meta.env.API_URL ?? process.env.API_URL;
const projects: { docs: Project[] } = await fetch(
    `${apiUrl}/api/projects?depth=1&sort=createdAt&locale=${locale}`,
).then((res) => res.json());
---

<section id="cards" class="section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag mono">
                <LucideIcon name="code-2" size={16} />
                <span>{t.chapterTag}</span>
            </span>
            <h2 class="section-title">
                {t.titlePrefix}
                <span class="title-accent">{t.titleItalic}</span>
                <span class="marker">{t.titleMarker}</span>
            </h2>
            <p class="section-lede">
                {t.ledePrefix}
                <span class="strike">{t.ledeStrike}</span>
                <em>{t.ledeItalic}</em>
            </p>
        </div>

        <ul class="cards-grid">
            {
                projects.docs.map((project, index) => (
                    <li class="card-item">
                        <ProjectCard
                            project={project}
                            index={index}
                            stampLabel={t.stamps[index % t.stamps.length]}
                        />
                    </li>
                ))
            }
        </ul>
    </div>
</section>

<style>
    .section {
        padding-top: 3rem;
        padding-bottom: 4rem;
    }

    @media (min-width: 768px) {
        .section {
            padding-top: 5rem;
            padding-bottom: 6rem;
        }
    }

    .section-header {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.25rem;
        margin-bottom: 4rem;
    }

    .section-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 0.75rem;
        background: var(--surface);
        color: var(--ink);
        border: 2px solid var(--border);
        border-radius: 0.5rem;
        font-size: 0.75rem;
        text-transform: uppercase;
        font-weight: 500;
        box-shadow: 3px 3px 0 0 var(--shadow);
        transform: rotate(-1.5deg);
    }

    .section-title {
        font-family: var(--font-display);
        font-size: var(--headline);
        text-transform: uppercase;
        letter-spacing: -0.02em;
        line-height: 1;
        margin: 0;
        color: var(--ink);
    }

    .title-accent {
        font-style: italic;
        color: var(--accent);
        font-weight: 400;
    }

    .section-lede {
        margin: 0;
        font-size: 1rem;
        font-weight: 500;
        color: var(--ink-muted);
        max-width: 36rem;
    }

    .section-lede em {
        color: var(--ink);
        font-style: italic;
        font-weight: 600;
    }

    .strike {
        text-decoration: line-through;
        text-decoration-thickness: 2px;
        text-decoration-color: var(--accent);
        opacity: 0.7;
    }

    .cards-grid {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .cards-grid {
            grid-template-columns: repeat(2, 1fr);
            gap: 2.5rem;
        }
    }

    .card-item {
        display: flex;
    }
</style>
