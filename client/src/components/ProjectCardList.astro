---
import type { Project } from '../types/payload-types';
import LucideIcon from './LucideIcon.astro';
import ProjectCard from './ProjectCard.astro';

const apiUrl = import.meta.env.API_URL ?? process.env.API_URL;
const projects: { docs: Project[] } = await fetch(
    `${apiUrl}/api/projects?depth=1&sort=createdAt`,
).then((res) => res.json());
---

<section id="cards" class="section">
    <div class="container">
        <div class="section-header">
            <LucideIcon name="code-2" size={36} class="section-icon" />
            <h2 class="section-title">Selected Work</h2>
        </div>

        <ul class="cards-grid">
            {
                projects.docs.map((project, index) => (
                    <li class="card-item">
                        <ProjectCard project={project} index={index} />
                    </li>
                ))
            }
        </ul>
    </div>
</section>

<style>
    .section {
        padding-top: 3rem;
        padding-bottom: 3rem;
    }

    .section-header {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        background: var(--surface);
        padding: 1rem 2rem;
        border: 4px solid var(--border);
        border-radius: 9999px;
        box-shadow: 8px 8px 0 0 var(--shadow);
        transform: rotate(-2deg);
        margin-bottom: 4rem;
    }

    .section-title {
        font-size: clamp(1.75rem, 4vw, 3rem);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.02em;
        margin: 0;
    }

    :global(.section-icon) {
        color: var(--accent);
    }

    .cards-grid {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: 1fr;
        gap: 2.5rem;
    }

    @media (min-width: 768px) {
        .cards-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .card-item {
        display: flex;
    }
</style>
