---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocale, getLocalizedPath } from '../i18n/utils';
import { getDictionary, locales } from '../i18n/ui';

interface Props {
    title: string;
    description: string;
    image?: string;
}

const { title, description, image } = Astro.props;
const locale = getLocale(Astro);
const dict = await getDictionary(locale);
const siteURL = Astro.site ? Astro.site.toString() : 'https://jan-kessler.com/';
const canonicalURL = new URL(Astro.url.pathname, siteURL);
const alternates = locales.map((alt) => ({
    locale: alt,
    href: new URL(
        getLocalizedPath(Astro.url.pathname, alt, locale),
        siteURL,
    ).toString(),
}));
---

<!doctype html>
<html lang={dict.htmlLang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/favicon/apple-touch-icon.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href="/favicon/favicon-32x32.png"
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href="/favicon/favicon-16x16.png"
        />
        <link rel="manifest" href="/favicon/site.webmanifest" />
        <meta name="theme-color" content="#eaf1ec" media="(prefers-color-scheme: light)" />
        <meta name="theme-color" content="#11181a" media="(prefers-color-scheme: dark)" />

        <link rel="sitemap" href="/sitemap-index.xml" />

        <link
            rel="preload"
            href="/fonts/Space_Grotesk/latin.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/Archivo_Black/latin.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />
        <link
            rel="preload"
            href="/fonts/JetBrains_Mono/JetBrainsMono-VariableFont_wght.woff2"
            as="font"
            type="font/woff2"
            crossorigin
        />

        <!-- SEO meta tags -->
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL.toString()} />
        {
            alternates.map((alt) => (
                <link rel="alternate" hreflang={alt.locale} href={alt.href} />
            ))
        }
        <link rel="alternate" hreflang="x-default" href={alternates[0].href} />

        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL.toString()} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:locale" content={locale === 'de' ? 'de_DE' : 'en_US'} />
        {
            image && (
                <meta property="og:image" content={new URL(image, siteURL).toString()} />
            )
        }

        <!-- Twitter -->
        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL.toString()} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        {
            image && (
                <meta
                    property="twitter:image"
                    content={new URL(image, siteURL).toString()}
                />
            )
        }

        <script is:inline>
            (() => {
                const stored = localStorage.getItem('theme');
                const prefersDark = window.matchMedia(
                    '(prefers-color-scheme: dark)',
                ).matches;
                const theme =
                    stored === 'light' || stored === 'dark'
                        ? stored
                        : prefersDark
                          ? 'dark'
                          : 'light';
                document.documentElement.dataset.theme = theme;
                document.documentElement.style.colorScheme = theme;
                if (theme === 'dark') {
                    document.documentElement.classList.add('dark');
                }
            })();
        </script>

        <script
            is:inline
            defer=""
            data-api="/api/event"
            data-domain="jan-kessler.com"
            src="/js/script.js"></script>
    </head>
    <body>
        <Header />
        <slot />
        <Footer />
    </body>
</html>

<style is:global>
    /* fonts (self-hosted) */
    @font-face {
        font-family: 'Archivo Black';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/Archivo_Black/latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7,
            U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F,
            U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F,
            U+A720-A7FF;
    }
    @font-face {
        font-family: 'Archivo Black';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/Archivo_Black/latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6,
            U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122,
            U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }

    @font-face {
        font-family: 'Space Grotesk';
        font-style: normal;
        font-weight: 300 700;
        font-display: swap;
        src: url('/fonts/Space_Grotesk/latin-ext.woff2') format('woff2');
        unicode-range: U+0100-02BA, U+02BD-02C5, U+02C7-02CC, U+02CE-02D7,
            U+02DD-02FF, U+0304, U+0308, U+0329, U+1D00-1DBF, U+1E00-1E9F,
            U+1EF2-1EFF, U+2020, U+20A0-20AB, U+20AD-20C0, U+2113, U+2C60-2C7F,
            U+A720-A7FF;
    }
    @font-face {
        font-family: 'Space Grotesk';
        font-style: normal;
        font-weight: 300 700;
        font-display: swap;
        src: url('/fonts/Space_Grotesk/latin.woff2') format('woff2');
        unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6,
            U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122,
            U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
    }

    @font-face {
        font-family: 'JetBrains Mono';
        font-style: normal;
        font-weight: 100 800;
        font-display: swap;
        src: url('/fonts/JetBrains_Mono/JetBrainsMono-VariableFont_wght.woff2')
            format('woff2');
    }

    /* layout */
    :root {
        --container-padding: 1.5rem;
        --max-width: 72rem;

        /* card palette — cycled across project cards */
        --card-1: #ffe066; /* soft yellow */
        --card-2: #ffb4a2; /* peach */
        --card-3: #c7b8ea; /* lavender */
        --card-4: #b8e0d2; /* mint */

        /* surface for project cards always uses dark ink for legibility */
        --card-ink: #1a1612;
    }

    /* palette — light (cool mint wash + coral accent) */
    :root[data-theme='light'] {
        --background: #eaf1ec;
        --surface: #ffffff;
        --ink: #11181a;
        --ink-muted: #56636a;
        --ink-inverse: #eaf1ec;
        --border: #11181a;
        --shadow: #11181a;
        --accent: #ff5252;
        --accent-soft: #ffe066;
    }

    /* palette — dark (deep petrol + brighter coral) */
    :root[data-theme='dark'] {
        --background: #11181a;
        --surface: #1c2528;
        --ink: #eaf1ec;
        --ink-muted: #9aa8ad;
        --ink-inverse: #11181a;
        --border: #eaf1ec;
        --shadow: #eaf1ec;
        --accent: #ff7b7b;
        --accent-soft: #ffe066;
    }

    /* type scale */
    :root {
        --display: clamp(4rem, 14vw, 10rem);
        --headline: clamp(2rem, 5vw, 3.5rem);
        --subheadline: clamp(1.25rem, 2.5vw, 1.75rem);
        --body: 1.0625rem;
        --small: 0.8125rem;

        --font-display: 'Archivo Black', 'Space Grotesk', system-ui, sans-serif;
        --font-sans:
            'Space Grotesk', system-ui, -apple-system, BlinkMacSystemFont,
            'Segoe UI', sans-serif;
        --font-mono:
            'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas,
            monospace;
    }

    *,
    *::before,
    *::after {
        box-sizing: border-box;
    }

    /* selection */
    ::selection {
        background: var(--accent);
        color: #ffffff;
    }

    /* document */
    html {
        font-family: var(--font-sans);
        background-color: var(--background);
        color: var(--ink);
    }

    body {
        margin: 0;
        font-size: var(--body);
        font-weight: 500;
        line-height: 1.55;
        overflow-x: hidden;
        padding-bottom: 4rem;
    }

    a {
        color: inherit;
        text-decoration: none;
    }

    /* shared utilities */
    .container {
        max-width: var(--max-width);
        margin: 0 auto;
        padding-left: var(--container-padding);
        padding-right: var(--container-padding);
    }

    .mono {
        font-family: var(--font-mono);
        letter-spacing: 0.04em;
    }

    /* hand-drawn marker highlight — paint behind the word */
    .marker {
        background-image: linear-gradient(
            104deg,
            transparent 0.9%,
            var(--marker-color, var(--accent-soft)) 2.4%,
            var(--marker-color, var(--accent-soft)) 5.8%,
            color-mix(in srgb, var(--marker-color, var(--accent-soft)) 88%, transparent) 93%,
            color-mix(in srgb, var(--marker-color, var(--accent-soft)) 65%, transparent) 96%,
            transparent 98%
        );
        background-repeat: no-repeat;
        background-position: 0 50%;
        background-size: 100% 100%;
        padding: 0.05em 0.2em;
        color: var(--card-ink);
        box-decoration-break: clone;
        -webkit-box-decoration-break: clone;
    }

    /* washi tape strip */
    .tape {
        position: absolute;
        width: 5rem;
        height: 1.25rem;
        background: var(--accent-soft);
        border: 2px solid var(--border);
        opacity: 0.92;
        box-shadow: 0 1px 0 0 rgba(0, 0, 0, 0.08);
    }

    /* rubber stamp sticker */
    .stamp {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.6875rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        padding: 0.3rem 0.55rem;
        border: 2px solid currentColor;
        border-radius: 0.25rem;
        color: var(--accent);
    }

    /* animations */
    .fade-in {
        opacity: 0;
        transition: opacity 0.7s ease-in;
    }

    .fade-in.visible {
        opacity: 1;
    }

    .slide-in {
        transform: translateX(2rem);
        opacity: 0;
        transition:
            transform 0.7s ease-out,
            opacity 0.7s ease-in;
    }

    .slide-in.visible {
        transform: translateX(0);
        opacity: 1;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const processIntro = () => {
            document.removeEventListener('visibilitychange', processIntro);

            const animatedElements = document.querySelectorAll(
                '.fade-in, .slide-in',
            );

            setTimeout(() => {
                animatedElements.forEach((element: Element) => {
                    element.classList.add('visible');
                });
            }, 150);
        };

        if (document.hidden) {
            document.addEventListener('visibilitychange', processIntro);
        } else {
            processIntro();
        }
    });
</script>
